# loadbearing configuration (all optional)

# Which provider drives the analysis: ollama | openai | anthropic
LOADBEARING_PROVIDER=ollama
# Override the model for whichever provider is selected
# LOADBEARING_MODEL=gemma4:e4b
# Comma-separated transcript language preference
LOADBEARING_LANGUAGES=en
# Chunking / output budgets
LOADBEARING_MAX_CHARS=12000
# Ceiling for the synthesis output (a cap, not a target)
LOADBEARING_MAX_TOKENS=30000
# Parallel workers for the map stage (bounded to respect cloud rate limits)
LOADBEARING_MAX_WORKERS=4

# Ollama (default; no key needed, just a running daemon)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (optional) — pip install 'loadbearing[openai]'
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional) — pip install 'loadbearing[anthropic]'
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
